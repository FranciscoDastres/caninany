{
  "name": "caninany",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de agendamiento para servicios veterinarios de higiene.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0 <11"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose up --build --remove-orphans",
    "dev:up": "docker compose up --build -d --remove-orphans",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f backend frontend db",
    "dev:status": "docker compose ps",
    "dev:workspace": "corepack pnpm turbo run dev --parallel",
    "dev:backend": "corepack pnpm --filter @caninany/backend dev",
    "dev:frontend": "corepack pnpm --filter @caninany/frontend dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "performance:check": "pnpm --filter @caninany/frontend build && pnpm --filter @caninany/frontend performance:check",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @caninany/backend prisma:generate",
    "db:migrate": "pnpm --filter @caninany/backend prisma:migrate",
    "db:studio": "pnpm --filter @caninany/backend prisma:studio",
    "docker:dev": "npm run dev",
    "docker:down": "npm run dev:down"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0"
  }
}
