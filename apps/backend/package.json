{
  "name": "@caninany/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "pnpm prisma:generate && nest build",
    "dev": "pnpm prisma:generate && nest start --watch",
    "lint": "eslint src test",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm prisma:generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@caninany/shared": "workspace:*",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.26",
    "@nestjs/swagger": "11.4.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "dotenv": "17.4.2",
    "helmet": "8.2.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.21.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.26",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/node": "22.19.17",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
