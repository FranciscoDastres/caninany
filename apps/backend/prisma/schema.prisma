generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CLIENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ExternalIdentityProvider {
  GOOGLE
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum AppointmentService {
  BATH
  EAR_CLEANING
  BATH_AND_EAR_CLEANING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id                       String              @id @default(uuid()) @db.Uuid
  email                    String              @unique
  passwordHash             String?
  name                     String
  role                     UserRole            @default(CLIENT)
  status                   UserStatus          @default(ACTIVE)
  emailVerifiedAt          DateTime?
  phone                    String?
  avatarUrl                String?
  externalIdentities       ExternalIdentity[]
  sessions                 AuthSession[]
  authTokens               AuthToken[]
  pets                     Pet[]
  appointments             Appointment[]
  purchases                Purchase[]
  siteConfigurationUpdates SiteConfiguration[] @relation("SiteConfigurationUpdatedBy")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model ExternalIdentity {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @db.Uuid
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        ExternalIdentityProvider
  providerSubject String
  email           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime  @db.Timestamptz(3)
  lastUsedAt       DateTime  @default(now()) @db.Timestamptz(3)
  revokedAt        DateTime? @db.Timestamptz(3)
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime      @db.Timestamptz(3)
  usedAt    DateTime?     @db.Timestamptz(3)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)

  @@index([userId, type, usedAt])
  @@index([expiresAt])
}

model Pet {
  id            String        @id @default(uuid()) @db.Uuid
  ownerId       String        @db.Uuid
  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  breed         String?
  weightKg      Decimal       @db.Decimal(5, 2)
  dateOfBirth   DateTime?     @db.Date
  medicalNotes  String?
  behaviorNotes String?
  archivedAt    DateTime?
  appointments  Appointment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([ownerId, archivedAt])
}

model Appointment {
  id              String             @id @default(uuid()) @db.Uuid
  customerId      String?            @db.Uuid
  customer        User?              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  petId           String?            @db.Uuid
  pet             Pet?               @relation(fields: [petId], references: [id], onDelete: Restrict)
  ownerName       String?
  phone           String?
  email           String?
  petName         String?
  petWeightKg     Decimal?           @db.Decimal(5, 2)
  service         AppointmentService
  startsAt        DateTime           @db.Timestamptz(3)
  endsAt          DateTime           @db.Timestamptz(3)
  durationMinutes Int
  status          AppointmentStatus  @default(PENDING)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([customerId, startsAt])
  @@index([petId, startsAt])
  @@index([startsAt, endsAt])
}

model Purchase {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @db.Uuid
  customer    User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  description String
  total       Decimal  @db.Decimal(12, 2)
  purchasedAt DateTime @default(now()) @db.Timestamptz(3)
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, purchasedAt])
}

model SiteConfiguration {
  id                  String   @id @default("principal")
  heroTitle           String
  heroHighlight       String
  heroDescription     String
  heroImageUrl        String
  servicesEyebrow     String
  servicesTitle       String
  servicesDescription String
  updatedById         String?  @db.Uuid
  updatedBy           User?    @relation("SiteConfigurationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
